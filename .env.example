# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# Full public URL of the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# next-auth v5 also reads AUTH_SECRET
AUTH_SECRET=

# ── Application ───────────────────────────────────────────────────────────────
# Public base URL used for canonical links, OG, and email links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Author/brand website (shown in footer)
NEXT_PUBLIC_AUTHOR_WEBSITE=https://siferone.com

# ── Email (Resend — preferred) ────────────────────────────────────────────────
# Resend API key (https://resend.com) — recommended for DKIM/SPF/DMARC
RESEND_API_KEY=

# From address — must be a verified domain in Resend dashboard
EMAIL_FROM=FacturApp <no-reply@yourdomain.com>

# ── PDF Storage (S3 / Cloudflare R2) ─────────────────────────────────────────
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=      # Cloudflare R2 or custom endpoint

# ── Email (Nodemailer / Gmail) ────────────────────────────────────────────────
# Used for password-reset emails when Resend is not configured
# NODEMAILER_EMAIL=
# NODEMAILER_PW=

# ── Database (Phase 1 — required) ────────────────────────────────────────────
# Provision at Neon (https://neon.tech) or Supabase for free
DATABASE_URL=postgresql://user:pass@host:5432/facturapp

# ── Rate limiting (Phase 1 — optional, graceful degradation without it) ──────
# Provision at https://upstash.com (free tier available)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Observability (Phase 5) ───────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
